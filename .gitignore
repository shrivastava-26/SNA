backend/data/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
backend/backend.log

# ── OS / editor artifacts ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── TypeScript cache ──────────────────────────────────────────────────────
*.tsbuildinfo
